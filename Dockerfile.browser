# BackIssue WITH the browser stack — for a deployment that runs a plugin which
# drives a real browser. It bundles Chromium + Xvfb (~1GB). Most installs do
# not need this; the default lean Dockerfile omits it.
#
# BackIssue in a Linux container. Sites behind Cloudflare block true-headless
# Chromium — so we run a REAL (headed) browser against a virtual X display
# (Xvfb). The entrypoint starts Xvfb and then runs the app, giving the headed
# browser a fake screen to render into with no physical display.
FROM node:22-bookworm

# Xvfb = the virtual display. Chromium's own libraries are installed by
# `patchright install --with-deps` below.
RUN apt-get update \
    && apt-get install -y --no-install-recommends xvfb xauth \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install JS deps first (layer caching), then Chromium + its system libraries.
COPY package.json package-lock.json* ./
RUN npm install --omit=dev
RUN npx patchright install --with-deps chromium

COPY . .
# Build the web UI (Svelte → frontend/dist, which the server serves). Dev
# dependencies stay inside frontend/ and never reach the runtime image layers
# that matter; prune them after the build to keep the image lean.
# Drop the committed lockfile first: it may have been generated on another OS
# (e.g. Windows), and npm's optional-deps bug then skips this platform's native
# bundler binding (@rolldown/binding-*). Removing it forces a fresh resolve for
# the build platform. See npm/cli#4828.
RUN rm -f frontend/package-lock.json \
    && npm --prefix frontend install \
    && npm --prefix frontend run build \
    && rm -rf frontend/node_modules

# Normalize line endings (repo may be checked out with CRLF on Windows) and make
# the entrypoint executable.
RUN sed -i 's/\r$//' /app/docker/entrypoint-browser.sh && chmod +x /app/docker/entrypoint-browser.sh

# Persisted data lives on the mounted volume, not in the image: point the app's
# writable paths (db, settings, downloads, profile, staging, plugins) at /data.
ENV NODE_ENV=production
ENV DATA_DIR=/data
ENV PLUGINS_DIR=/data/plugins
# No GPU in a container — render WebGL in software (SwiftShader) so the browser
# fingerprint is complete. A browser reporting no WebGL is itself a bot signal.
ENV CHROMIUM_EXTRA_ARGS="--use-gl=angle --use-angle=swiftshader --enable-unsafe-swiftshader"
VOLUME ["/data"]
EXPOSE 8787

# Build provenance: release builds leave the defaults; dev/nightly builds pass
# BUILD_CHANNEL (+ commit sha) so the app reports e.g. "0.5.0-dev.a1b2c3d".
# Zero-byte config layers — declared LAST on purpose: a per-commit ARG placed
# above the fat layers (npm install, Chromium) would bust their cache and make
# every image update a full ~1GB re-download.
ARG BUILD_CHANNEL=release
ARG BUILD_SHA=""
ENV BUILD_CHANNEL=$BUILD_CHANNEL
ENV BUILD_SHA=$BUILD_SHA

# The entrypoint starts Xvfb (the virtual display) then execs the command, so the
# headed browser has a screen to render into with no physical display attached.
ENTRYPOINT ["/app/docker/entrypoint-browser.sh"]
CMD ["node", "src/index.js"]
